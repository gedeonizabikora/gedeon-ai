{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile data and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Stores a single chat message.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "image": { "type": "string" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    },
    "AdminConfig": {
      "title": "Admin Configuration",
      "description": "Empty entry to mark a UID as admin.",
      "type": "object",
      "properties": {
        "description": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "admins/{userId}": {
      "schema": "AdminConfig",
      "description": "Collection of admin UIDs."
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Collection of chat messages organized by chat session."
    }
  }
}
